# Copy to .env and fill in. Never commit the real .env.

# Public hostname for nginx + certbot. Must already point to this box.
DOMAIN=api.mempool.texitcoin.org
LETSENCRYPT_EMAIL=admin@texitcoin.org

# RPC credentials for the spinner-managed texitcoind running on the HOST.
# Defaults match node-spinner; replace with whatever the spinner generated.
RPC_USER=txc_admin
RPC_PASSWORD=CHANGE_ME_STRONG_RANDOM_PASSWORD
RPC_PORT=15739
P2P_PORT=15740

# MariaDB credentials for the mempool backend stats DB.
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=mempool
MYSQL_USER=mempool
MYSQL_PASSWORD=change-me-mempool
