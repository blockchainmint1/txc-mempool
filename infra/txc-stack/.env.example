# Copy to .env and fill in. Never commit the real .env.

# Public hostname for nginx + certbot. Must already point to this box.
DOMAIN=mempool.example.com

# Email for Let's Encrypt registration.
LETSENCRYPT_EMAIL=admin@example.com

# RPC credentials for texitcoind — random strings, never reused elsewhere.
RPC_USER=txcrpc
RPC_PASSWORD=change-me-to-a-long-random-string

# MariaDB credentials for the mempool backend stats DB.
MYSQL_ROOT_PASSWORD=change-me-too
MYSQL_DATABASE=mempool
MYSQL_USER=mempool
MYSQL_PASSWORD=change-me-three

# Which git ref of texitcoin/texitcoin to build. Pin to a tag in prod.
TEXITCOIN_GIT_REF=master
